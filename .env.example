# --- DJANGO ---
DJANGO_SECRET_KEY=django-insecure-p6^ped7h!8lxdm0f7pw%u0p!$h--b6lpi7aae5eli4(g)a+u@6
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.local

# --- DATABASE (Docker) ---
# Schema isolado `feed` dentro do banco compartilhado `atlas`.
POSTGRES_DB=atlas
POSTGRES_USER=atlas_user
POSTGRES_PASSWORD=atlas_password
DATABASE_URL=postgres://atlas_user:atlas_password@postgres:5432/atlas

# --- Notificações (feed é PRODUTOR) ---
# Publica o evento `notifications.create` na fila do notification-service ao
# curtir/comentar. Não roda worker. Best-effort: broker fora só é logado.
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//
NOTIFICATIONS_QUEUE=notifications

# --- JWT (opcional) ---
# Por padrão o token é assinado/validado com a DJANGO_SECRET_KEY. Para usar um
# segredo dedicado só ao JWT, defina o MESMO valor aqui, no auth-service e em
# todos os serviços que validam (track, scholarship, notification). Deixe vazio
# para manter o comportamento atual.
# JWT_SIGNING_KEY=
